@model PriMiClinic.Models.Appointment

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-4">

    <h2 class="page-title mb-4">
        📅 Book Appointment
    </h2>

    <div class="card shadow">

        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-action="Create">

                <div class="mb-3">

                    <label class="form-label">
                        Doctor
                    </label>

                    <select asp-for="DoctorId"
                            asp-items="ViewBag.Doctors"
                            class="form-control">
                    </select>

                </div>

                <div class="mb-3">

                    <label class="form-label">
                        Patient
                    </label>

                    <select asp-for="PatientId"
                            asp-items="ViewBag.Patients"
                            class="form-control">
                    </select>

                </div>

                <div class="mb-3">

                    <label asp-for="AppointmentDate"></label>

                    <input asp-for="AppointmentDate"
                           type="datetime-local"
                           class="form-control"/>

                </div>

                <button class="btn btn-primary">
                    Book Appointment
                </button>

            </form>

        </div>

    </div>

</div>